{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MediaFlow",
  "version": "0.1.0",
  "identifier": "com.sudo-rahman.mediaflow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [

    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**", "$HOME/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "ocr-models/*": "ocr-models"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Sudo-Rahman/RsExtractor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1ODQxOTc5NzcyMTBGRUUKUldUdUR5RjNlUm1FVmZqdmdGTVJkbHZoU2RXOFA4ZmYwcFFXUDhnS3ZleG5oWStjMFZtajhSUXUK"
    }
  }
}
